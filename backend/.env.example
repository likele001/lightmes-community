APP_NAME="LightMes Backend"
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DB_URL=mysql+pymysql://root:root@127.0.0.1:3306/lightmes?charset=utf8mb4
DB_ECHO=false
DB_AUTO_CREATE=true
DB_AUTO_SEED=true
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REMEMBER_ME_EXPIRE_MINUTES=10080
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./data/storage
# 云存储密钥推荐在平台总控「文件存储」中配置；以下为安装默认值（.env 可选）
FILE_MAX_UPLOAD_SIZE=20971520
FILE_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf,video/mp4
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=true
CRM_PUBLIC_POOL_RECYCLE_HOUR=2
CRM_PUBLIC_POOL_RECYCLE_MINUTE=0
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
TENCENT_COS_ENDPOINT=
TENCENT_COS_REGION=
TENCENT_COS_BUCKET=
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
QINIU_KODO_ENDPOINT=
QINIU_KODO_REGION=
QINIU_KODO_BUCKET=
QINIU_KODO_ACCESS_KEY=
QINIU_KODO_SECRET_KEY=
H5_PUBLIC_BASE_URL=http://127.0.0.1:5174
# 微信小程序登录（公众平台 - 开发 - 开发管理 - 开发设置）
WX_MINIAPP_APPID=
WX_MINIAPP_SECRET=
