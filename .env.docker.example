# LightMes Docker 环境变量（复制为 .env.docker 后使用）
# cp .env.docker.example .env.docker

# MySQL（compose 内服务名 mysql）
MYSQL_ROOT_PASSWORD=lightmes_root
MYSQL_DATABASE=lightmes
MYSQL_USER=lightmes
MYSQL_PASSWORD=lightmes

# 后端（api / celery 共用）
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DB_URL=mysql+pymysql://lightmes:lightmes@mysql:3306/lightmes?charset=utf8mb4
DB_ECHO=false
DB_AUTO_CREATE=false
DB_AUTO_SEED=false
JWT_SECRET=docker_dev_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REMEMBER_ME_EXPIRE_MINUTES=10080

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=true

STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=/app/data/storage
FILE_MAX_UPLOAD_SIZE=104857600

# Docker 宿主机端口（避开 8000/8080 等常见端口，可按机器情况改）
DOCKER_API_PORT=9018
STAGING_PORT_ADMIN=9010
STAGING_PORT_H5=9011
STAGING_PORT_REGISTER=9012

# staging 对外 URL（与 STAGING_PORT_* 一致；飞书/企微 OAuth 联调时改为实际域名）
PUBLIC_BASE_URL=http://localhost:9010
H5_PUBLIC_BASE_URL=http://localhost:9011

# entrypoint
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_WAIT_SECONDS=90
