{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"]
  }
}

